# Configuración de la API El Grano de Oro

# Google Gemini API Key (Requerido para el Chat Assistant)
# Consigue una en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_aqui

# URL de la base de datos (Opcional, por defecto usa SQLite)
# Ejemplo para PostgreSQL: postgresql://user:password@localhost:5432/dbname
# DATABASE_URL=sqlite:///./elgranodeoro.db

# URL del Frontend (Para configurar CORS en producción)
# Ejemplo: https://elgranodeoro.vercel.app
FRONTEND_URL=http://localhost:5173

# Configuración de Email (Opcional, usa Mailtrap por defecto)
# MAILTRAP_USER=tu_usuario
# MAILTRAP_PASS=tu_password
